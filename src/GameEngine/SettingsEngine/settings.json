{
    "windows_size": [
        {
            "heith": 800,
            "weith": 600
        }
    ],
    "shaders": [
        {
            "vertex_shader": [
                "#version 460\n",
                "layout(location = 0) in vec3 vertex_position;",
                "layout(location = 1) in vec3 vertex_color;",
                "out vec3 color;",
                "void main() {",
                "color = vertex_color;",
                "gl_Position = vec4(vertex_position, 1.0);",
                "}"
            ],
            "fragment_shader": [
                "#version 460\n",
                "in vec3 color;",
                "out vec4 frag_color;",
                "void main() {",
                "frag_color = vec4(color, 1.0);",
                "}"
            ]
        }
    ]
}